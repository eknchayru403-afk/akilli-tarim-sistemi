{
  "info": {
    "name": "ATYS — Akıllı Tarım Yönetim Sistemi API v1",
    "_postman_id": "atys-api-v1-collection",
    "description": "Akıllı Tarım Yönetim Sistemi REST API endpoint'leri.\n\nKullanım:\n1. Environment'ta BASE_URL ve TOKEN değişkenlerini ayarlayın.\n2. Önce 'Token Al (Login)' isteğini gönderin — token otomatik environment'a kaydedilir.\n3. Diğer istekleri JWT Bearer token ile gönderin.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "REFRESH_TOKEN",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{TOKEN}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔐 Kimlik Doğrulama (Auth)",
      "item": [
        {
          "name": "Token Al (Login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('TOKEN', body.access);",
                  "    pm.collectionVariables.set('REFRESH_TOKEN', body.refresh);",
                  "    pm.test('Token alındı', () => pm.expect(body.access).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/v1/token/",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "token", ""]
            },
            "description": "Kullanıcı adı ve şifre ile JWT access + refresh token alır.\n\nBaşarılı yanıt:\n```json\n{\n  \"access\": \"eyJ...\",\n  \"refresh\": \"eyJ...\"\n}\n```"
          },
          "response": []
        },
        {
          "name": "Token Yenile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('TOKEN', body.access);",
                  "    pm.test('Token yenilendi', () => pm.expect(body.access).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{REFRESH_TOKEN}}\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/v1/token/refresh/",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "token", "refresh", ""]
            },
            "description": "Refresh token ile yeni access token alır."
          },
          "response": []
        },
        {
          "name": "Token Doğrula",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{TOKEN}}\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/v1/token/verify/",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "token", "verify", ""]
            },
            "description": "Bir token'ın geçerli olup olmadığını doğrular. Geçerliyse 200, değilse 401 döner."
          },
          "response": []
        }
      ]
    },
    {
      "name": "🌾 Tarla Yönetimi (Fields)",
      "item": [
        {
          "name": "Tarla Listesi",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Durum 200', () => pm.response.to.have.status(200));",
                  "pm.test('Sayfalı yanıt', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('results');",
                  "    pm.expect(body).to.have.property('count');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/v1/fields/",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "fields", ""],
              "query": [
                { "key": "status", "value": "planted", "disabled": true },
                { "key": "soil_type", "value": "killi", "disabled": true },
                { "key": "name", "value": "kuzey", "disabled": true },
                { "key": "page", "value": "1", "disabled": true },
                { "key": "page_size", "value": "10", "disabled": true }
              ]
