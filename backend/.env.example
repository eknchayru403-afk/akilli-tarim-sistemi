SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database: sqlite3 (varsayılan) | postgresql | mysql
# DB_ENGINE=django.db.backends.sqlite3

# PostgreSQL (docker compose postgres servisi)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=akilli_tarim
# DB_USER=ats
# DB_PASSWORD=ats
# DB_HOST=localhost
# DB_PORT=5432

# MySQL
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=akilli_tarim
# DB_USER=root
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=3306

# MQTT (EMQX — docker compose up sonrası)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TLS=False
MQTT_USERNAME=ingest
MQTT_PASSWORD=change-me-ingest-secret
MQTT_CLIENT_ID=ats-ingest-1
MQTT_ENV=dev
MQTT_TOPIC_VERSION=v1
